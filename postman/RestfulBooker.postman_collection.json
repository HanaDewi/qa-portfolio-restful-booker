                  "    pm.expect(jsonData.length).to.be.above(0);\r",
                  "    // Verifikasi setiap item punya bookingid\r",
                  "    jsonData.forEach(item => {\r",
                  "        pm.expect(item).to.have.property('bookingid');\r",
                  "    });\r",
                  "});\r",
