    {
      "name": "03-Create Booking",
      "item": [
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - Created', function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  " \r",
                  "pm.test('Response has bookingid', function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData).to.have.property('bookingid');\r",
                  "    pm.expect(jsonData.bookingid).to.be.a('number');\r",
                  "    // Simpan bookingId untuk request selanjutnya!\r",
                  "    pm.environment.set('booking_id', jsonData.bookingid);\r",
                  "    console.log('Booking ID saved:', jsonData.bookingid);\r",
                  "});\r",
                  " \r",
                  "pm.test('Booking data matches input', function () {\r",
                  "    const b = pm.response.json().booking;\r",
                  "    pm.expect(b.firstname).to.eql('John');\r",
                  "    pm.expect(b.lastname).to.eql('Doe');\r",
                  "    pm.expect(b.totalprice).to.eql(150);\r",
                  "    pm.expect(b.depositpaid).to.eql(true);\r",
                  "    pm.expect(b.bookingdates.checkin).to.eql('2025-06-01');\r",
                  "    pm.expect(b.bookingdates.checkout).to.eql('2025-06-05');\r",
                  "    pm.expect(b.additionalneeds).to.eql('Breakfast');\r",
                  "});\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
